# ── Postgres ─────────────────────────────────────────────
# Auto-injected by Vercel when you attach a Vercel Postgres store.
# For local dev, copy the values from Vercel > Storage > your DB > .env.local tab.
POSTGRES_URL=

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring Price IDs (create in Stripe > Products). Each is a monthly price.
STRIPE_PRICE_BASIC=price_xxx      # The Footprint  ($69/mo)
STRIPE_PRICE_ENGINE=price_xxx     # The Engine     ($199/mo)
STRIPE_PRICE_COMMAND=price_xxx    # The Command Centre ($1,490/mo)
