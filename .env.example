# ── Postgres ─────────────────────────────────────────────
# Railway injects DATABASE_URL automatically once you add a Postgres service
# and reference it from the app service. For local dev, paste the DB's public URL.
# Append ?sslmode=require if connecting over Railway's public proxy.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurring (monthly) Price IDs from Stripe > Products
STRIPE_PRICE_BASIC=price_xxx      # The Footprint       ($69/mo)
STRIPE_PRICE_ENGINE=price_xxx     # The Engine          ($199/mo)
STRIPE_PRICE_COMMAND=price_xxx    # The Command Centre  ($1,490/mo)

# Railway sets PORT automatically; default for local dev:
PORT=3000
